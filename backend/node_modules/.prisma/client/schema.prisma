generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  password         String
  role             Role      @default(BUSINESS)
  isVerified       Boolean   @default(false)
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  business  Business?
  caProfile CAProfile?
}

enum Role {
  SUPER_ADMIN
  CA_PARTNER
  BUSINESS
  BUSINESS_STAFF
}

model CAProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  firmName      String
  icapNumber    String?
  phone         String?
  address       String?
  commissionPct Float    @default(0)
  referralCode  String?  @unique
  createdAt     DateTime @default(now())

  user    User       @relation(fields: [userId], references: [id])
  clients Business[]
}

model Business {
  id            String   @id @default(cuid())
  userId        String   @unique
  caId          String?
  businessName  String
  ntn           String   @unique
  strn          String   @unique
  address       String
  city          String
  phone         String
  businessType  String
  securityToken String?
  posId         String?
  isWhitelisted Boolean  @default(false)
  createdAt     DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id])
  ca           CAProfile?    @relation(fields: [caId], references: [id])
  branches     Branch[]
  invoices     Invoice[]
  subscription Subscription?
}

model Branch {
  id         String   @id @default(cuid())
  businessId String
  branchName String
  address    String
  city       String
  latitude   Float
  longitude  Float
  posType    String
  macAddress String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  business Business  @relation(fields: [businessId], references: [id])
  invoices Invoice[]
}

model Invoice {
  id                String        @id @default(cuid())
  businessId        String
  branchId          String?
  invoiceType       InvoiceType
  invoiceDate       DateTime
  buyerNtn          String?
  buyerCnic         String?
  buyerName         String?
  saleType          String
  totalAmount       Decimal
  totalSalesTax     Decimal
  totalFed          Decimal       @default(0)
  totalDiscount     Decimal       @default(0)
  fbrInvoiceNo      String?
  status            InvoiceStatus @default(PENDING)
  errorMessage      String?
  retryCount        Int           @default(0)
  pdfUrl            String?
  createdAt         DateTime      @default(now())
  sentAt            DateTime?
  originalInvoiceId String?
  amendmentReason   String?

  business Business      @relation(fields: [businessId], references: [id])
  branch   Branch?       @relation(fields: [branchId], references: [id])
  items    InvoiceItem[]
}

enum InvoiceType {
  SALE
  PURCHASE
  DEBIT_NOTE
  CREDIT_NOTE
}

enum InvoiceStatus {
  PENDING
  SENT
  FAILED
  RETRY
  AMENDED
}

model InvoiceItem {
  id             String  @id @default(cuid())
  invoiceId      String
  hsCode         String
  productCode    String?
  description    String
  quantity       Decimal
  uom            String
  rate           Decimal
  totalAmount    Decimal
  salesTax       Decimal
  sroSchedule    String
  fed            Decimal @default(0)
  withholdingTax Decimal @default(0)
  discount       Decimal @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

model Subscription {
  id           String    @id @default(cuid())
  businessId   String    @unique
  planName     String
  monthlyPrice Decimal
  invoiceLimit Int
  isActive     Boolean   @default(true)
  startDate    DateTime
  endDate      DateTime?
  createdAt    DateTime  @default(now())

  business Business  @relation(fields: [businessId], references: [id])
  payments Payment[]
}

model Payment {
  id             String        @id @default(cuid())
  subscriptionId String
  amount         Decimal
  status         PaymentStatus
  method         String
  transactionId  String?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id])
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
}

// Add to your existing schema
model Permission {
  id    String @id @default(cuid())
  name  String @unique
  roles Role[]
}

model RolePermission {
  id           String   @id @default(cuid())
  role         Role
  permissionId String
  createdAt    DateTime @default(now())
}

// Update AuditLog (you already have it, just make sure it has these fields)
// Your AuditLog looks good, keep it as is

model HsCode {
  id          String @id @default(cuid())
  code        String
  description String
  fullEntry   String

  @@index([code])
  @@index([description])
}
